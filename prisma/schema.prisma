generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TECNICO
  USER
  CLIENTE
  COLETA
}

model User {
  id         String      @id @default(cuid())
  name       String
  email      String      @unique
  password   String
  role       Role        @default(USER)
  empresaId  String?     @map("empresa_id")
  empresa    Empresa?    @relation(fields: [empresaId], references: [id])
  createdAt  DateTime    @default(now()) @map("created_at")
  relatorios Relatorio[]
  atividades Atividade[]
  movimentacoes StockMovement[]
  planilhas  Planilha[]

  @@map("users")
}

model Empresa {
  id         String      @id @default(cuid())
  nome       String
  endereco   String?
  contato    String?
  createdAt  DateTime    @default(now()) @map("created_at")
  relatorios Relatorio[]
  atividades Atividade[]
  usuarios   User[]

  @@map("empresas")
}

model Profissional {
  id              String      @id @default(cuid())
  nome            String
  profissao       String
  especialidade   String?
  disponibilidade String?
  contato         String?
  portfolioUrl    String?     @map("portfolio_url")
  ativo           Boolean     @default(true)
  createdAt       DateTime    @default(now()) @map("created_at")
  atividades      Atividade[]
  atividadesSecundarias Atividade[] @relation("ProfissionalSecundario")

  @@map("profissionais")
}

model Relatorio {
  id         String   @id @default(cuid())
  empresaId  String   @map("empresa_id")
  empresa    Empresa  @relation(fields: [empresaId], references: [id])
  usuarioId  String?  @map("usuario_id")
  usuario    User?    @relation(fields: [usuarioId], references: [id])
  dataColeta DateTime @map("data_coleta")
  dados      Json
  pdfUrl     String?  @map("pdf_url")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("relatorios")
}

model Atividade {
  id             String          @id @default(cuid())
  data           DateTime
  tipo           TipoAtividade
  empresaId      String          @map("empresa_id")
  empresa        Empresa         @relation(fields: [empresaId], references: [id])
  usuarioId      String?         @map("usuario_id")
  usuario        User?           @relation(fields: [usuarioId], references: [id])
  profissionalId String?         @map("profissional_id")
  profissional   Profissional?   @relation(fields: [profissionalId], references: [id])
  profissional2Id String?        @map("profissional_2_id")
  profissional2  Profissional?   @relation("ProfissionalSecundario", fields: [profissional2Id], references: [id])
  titulo         String
  endereco       String?
  cidade         String?
  gpsLat         Float?          @map("gps_lat")
  gpsLng         Float?          @map("gps_lng")
  ajudaCusto     Boolean         @default(false) @map("ajuda_custo")
  transporte     Transporte?
  blitzHoras     Int?            @map("blitz_horas")
  horaEntrada    String?         @map("hora_entrada")
  horaSaida      String?         @map("hora_saida")
  qtdPalestras   Int?            @map("qtd_palestras")
  kmRodado       Float?          @map("km_rodado")
  colaboradores  Int             @default(0)
  materiais      String?
  status         StatusAtividade @default(AGENDADA)
  createdAt      DateTime        @default(now()) @map("created_at")
  movimentacoes  StockMovement[]

  @@map("atividades")
}

model Product {
  id          String         @id @default(cuid())
  name        String
  category    String
  unit        String         // Unidade de Medida (ex: Unidade, ml, Caixa)
  batches     StockBatch[]
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@map("products")
}

model StockBatch {
  id               String          @id @default(cuid())
  productId        String          @map("product_id")
  product          Product         @relation(fields: [productId], references: [id])
  batchNumber      String          @map("batch_number")
  expirationDate   DateTime        @map("expiration_date")
  initialQuantity  Float           @map("initial_quantity")
  currentQuantity  Float           @map("current_quantity")
  movements        StockMovement[]
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  @@map("stock_batches")
}

model StockMovement {
  id           String       @id @default(cuid())
  batchId      String       @map("batch_id")
  batch        StockBatch   @relation(fields: [batchId], references: [id])
  type         MovementType
  quantity     Float
  description  String?
  atividadeId  String?      @map("atividade_id")
  atividade    Atividade?   @relation(fields: [atividadeId], references: [id])
  userId       String?      @map("user_id")
  user         User?        @relation(fields: [userId], references: [id])
  date         DateTime     @default(now())
  createdAt    DateTime     @default(now()) @map("created_at")

  @@map("stock_movements")
}

enum TipoAtividade {
  BLITZ
  PALESTRA
  SIPAT
}

enum StatusAtividade {
  SOLICITADA
  AGENDADA
  REALIZADA
  CANCELADA
}

enum Transporte {
  MOTORISTA
  CARRO_PROPRIO
}

enum MovementType {
  ENTRADA
  SAIDA
}

model Arquivo {
  id        String   @id @default(cuid())
  nome      String
  tipo      String
  tamanho   Int
  url       String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("arquivos")
}

model Planilha {
  id              String   @id @default(cuid())
  nome            String
  tipo            String
  tamanho         Int
  arquivoPath     String   @map("arquivo_path")
  empresaNome     String?  @map("empresa_nome")
  dataColetaTexto String?  @map("data_coleta_texto")
  usuarioId       String?  @map("usuario_id")
  usuario         User?    @relation(fields: [usuarioId], references: [id])
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("planilhas")
}
